#!/usr/bin/env python3
import base64
import os
import subprocess
import sys


PNG_1X1 = base64.b64decode(
    "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAusB9WlAbm8AAAAASUVORK5CYII="
)


def _real_command():
    self_path = os.path.realpath(__file__)
    self_dir = os.path.dirname(self_path)
    for item in os.environ.get("PATH", "").split(os.pathsep):
        if not item:
            continue
        if os.path.realpath(item) == self_dir:
            continue
        candidate = os.path.join(item, "plantumlcli")
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            return candidate
    return None


def _write_placeholder(output_path: str):
    os.makedirs(os.path.dirname(output_path), exist_ok=True)
    if output_path.endswith(".svg"):
        text = """<svg xmlns="http://www.w3.org/2000/svg" width="640" height="160">
<rect width="640" height="160" fill="#f7f7f3"/>
<rect x="16" y="16" width="608" height="128" rx="12" fill="#ffffff" stroke="#8c8f74"/>
<text x="32" y="64" font-size="24" font-family="Arial, sans-serif" fill="#36381f">PlantUML placeholder</text>
<text x="32" y="102" font-size="16" font-family="Arial, sans-serif" fill="#686b54">Install PlantUML + Java to render the real diagram.</text>
</svg>
"""
        with open(output_path, "w", encoding="utf-8") as file:
            file.write(text)
    else:
        with open(output_path, "wb") as file:
            file.write(PNG_1X1)


def main():
    real = _real_command()
    if real:
        raise SystemExit(subprocess.call([real, *sys.argv[1:]]))

    output_path = None
    for index, arg in enumerate(sys.argv[1:], start=1):
        if arg == "-o" and index + 1 < len(sys.argv):
            output_path = sys.argv[index + 1]
            break
    if not output_path:
        raise SystemExit("plantumlcli shim could not find output path")
    _write_placeholder(output_path)


if __name__ == "__main__":
    main()

