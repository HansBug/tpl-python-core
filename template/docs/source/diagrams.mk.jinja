PLANTUMLCLI ?= plantumlcli
PYTHON ?= python

abspath_py = $(shell $(PYTHON) -c 'import os, sys; print(os.path.abspath(sys.argv[1]))' "$(1)")

SOURCE ?= .
PUMLS  := $(shell find ${SOURCE} -name '*.puml')
PNGS   := $(addsuffix .puml.png, $(basename ${PUMLS}))
SVGS   := $(addsuffix .puml.svg, $(basename ${PUMLS}))

%.puml.png: %.puml
	$(PLANTUMLCLI) -t png -o "$(call abspath_py,$@)" "$(call abspath_py,$<)"

%.puml.svg: %.puml
	$(PLANTUMLCLI) -t svg -o "$(call abspath_py,$@)" "$(call abspath_py,$<)"

build: ${SVGS} ${PNGS}

all: build

clean:
	rm -rf \
		$(shell find ${SOURCE} -name '*.puml.svg') \
		$(shell find ${SOURCE} -name '*.puml.png')
